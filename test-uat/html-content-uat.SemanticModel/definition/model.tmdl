model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-NZ
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["RepoRoot","corpus","lorem","stylesheet","hyperlinks"]

ref table corpus
ref table lorem
ref table stylesheet
ref table hyperlinks

ref cultureInfo en-US

