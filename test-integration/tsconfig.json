{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "lib": ["es2020", "dom"],
        "types": ["node", "@playwright/test"],
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "noEmit": true
    },
    "include": [
        "**/*.ts",
        "../src/sanitize-pipeline.ts",
        "../src/types.ts",
        "../src/visual-constants.ts"
    ]
}
