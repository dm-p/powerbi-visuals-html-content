        "@types/pretty": "^2.0.0",
        "@types/sanitize-html": "^2.15.0",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "@vitest/ui": "^4.0.16",
        "d3-selection": "^3.0.0",
        "eslint": "^8.46.0",
        "eslint-plugin-powerbi-visuals": "^0.8.1",
